# Copy this to .env for local development: cp .env.example .env
# quickstart fills in the auth + MLflow values for you.

# Databricks auth. On a lab such as Vocareum, ambient auth is already configured —
# leave these blank. Set DATABRICKS_CONFIG_PROFILE only if you use a named CLI profile.
# DATABRICKS_CONFIG_PROFILE=
# DATABRICKS_HOST=https://<your-workspace-here>.databricks.com
# DATABRICKS_TOKEN=dapi....

# MLflow — experiment for traces and the logged agent model
MLFLOW_EXPERIMENT_ID=
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"

# Frontend chat proxy
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300

# Agent config.
#   AKZO_CATALOG  Unity Catalog with the coatings data. Optional: defaults to
#                 current_catalog() (your assigned lab catalog on Vocareum). No 'main'
#                 fallback — if neither is set, the agent fails fast.
#   AKZO_SCHEMA   Optional, defaults to akzo_finance.
#   LLM_ENDPOINT  REQUIRED. A chat model serving endpoint you are entitled to. There is
#                 no default, so the agent never silently calls a model you did not pick.
# AKZO_CATALOG=
# AKZO_SCHEMA=akzo_finance
LLM_ENDPOINT=databricks-meta-llama-3-3-70b-instruct

# AKZO_LOCAL_TOOL=1 switches the lookup tool from the managed MCP server (default) to an
# in-process Spark fallback for local dev. Leave unset for the real managed-MCP path.
# AKZO_LOCAL_TOOL=

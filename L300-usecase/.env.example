# L300 Multi-domain Supervisor — local dev environment.
# Copy to .env:  cp .env.example .env
# Nothing here is hardcoded to a workspace; fill in your lab's values.

# --- Auth (pick one) -------------------------------------------------------
# Local: a Databricks CLI profile (recommended for Vocareum / your own workspace).
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://<your-workspace-host>
# DATABRICKS_TOKEN=dapi....

# --- Catalog / schemas (the shared data setup loaded these) ----------------
# Leave AKZO_CATALOG unset to use the workspace's current_catalog() (e.g. on Vocareum).
# AKZO_CATALOG=<your-catalog>
AKZO_FINANCE_SCHEMA=akzo_finance
AKZO_SCM_SCHEMA=akzo_scm
AKZO_COMMERCIAL_SCHEMA=akzo_commercial

# --- LLM + warehouse -------------------------------------------------------
# REQUIRED — a chat model serving endpoint you are entitled to. There is no code default,
# so the supervisor never silently calls a model you did not pick. E.g. a Foundation Model
# API endpoint such as databricks-claude-sonnet-4-5.
LLM_ENDPOINT=
# Serverless SQL warehouse for the governed text2sql fallback legs.
DATABRICKS_WAREHOUSE_ID=<your-warehouse-id>

# --- Genie spaces (one per domain) -----------------------------------------
# When set, that domain leg calls the REAL Genie space under the caller's identity (OBO).
# When blank, the leg falls back to instruction-driven text2sql over the bundled *_space.md.
FINANCE_SPACE_ID=
SCM_SPACE_ID=
COMMERCIAL_SPACE_ID=

# --- Optional: document tools over vector search ---------------------------
# Format: <catalog>/<schema>/<index-name>
VECTOR_SEARCH_INDEX=

# --- Lakebase (audit trail + Action Plane tables) --------------------------
# Workshop default (provisioned + verified). On a Vocareum lab, change to your assigned instance.
LAKEBASE_INSTANCE=akzo-workshop-lakebase
LAKEBASE_DBNAME=databricks_postgres
LAKEBASE_SCHEMA=akzo

# --- Action Plane connectors (mock external systems) -----------------------
# The governed HTTP path POSTs through the UC connection AKZO_HTTP_CONNECTION; the
# fallback posts directly to AKZO_MOCK_SYSTEMS_URL under the app SP token.
AKZO_HTTP_CONNECTION=akzo_external_systems
# AKZO_MOCK_SYSTEMS_URL=https://<your-mock-systems-app-host>

# --- MLflow ----------------------------------------------------------------
MLFLOW_EXPERIMENT_ID=
MLFLOW_TRACKING_URI=databricks
MLFLOW_REGISTRY_URI=databricks-uc

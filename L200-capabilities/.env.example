# Copy to .env for local development:  cp .env.example .env

# --- Auth ---
# On Vocareum you run inside the workspace, so leave these blank and use ambient auth.
# Locally, set a CLI profile or host/token:
# DATABRICKS_CONFIG_PROFILE=
# DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=dapi....

# --- MLflow ---
MLFLOW_EXPERIMENT_ID=
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"

# --- Agent config (nothing is workspace-specific by default) ---
AGENT_NAME=akzo-capabilities-agent
# REQUIRED — the agent fails fast if unset. Set to a serving endpoint you are
# entitled to, e.g. LLM_ENDPOINT=databricks-claude-sonnet-4-5
LLM_ENDPOINT=
# Your Unity Catalog holding the akzo_* schemas + UC-function tools.
# On a Vocareum lab, your assigned catalog.
AKZO_CATALOG=
AKZO_TOOLS_SCHEMA=akzo_tools
# Optional: attach a Genie space as a tool.
# AKZO_GENIE_SPACE_ID=01234567-89ab-cdef
# Optional extra MCP servers as "name|path" pairs, ';'-separated.
# AKZO_MCP_SERVERS=Vector Search: docs|/api/2.0/mcp/vector-search/<cat>/<schema>

# --- Frontend proxy ---
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300

# --- Lakebase short-term memory: set ONE of these ---
# LAKEBASE_INSTANCE_NAME=my-provisioned-instance
# LAKEBASE_AUTOSCALING_ENDPOINT=projects/<proj>/branches/<branch>/endpoints/primary
# LAKEBASE_AUTOSCALING_PROJECT=my-project
# LAKEBASE_AUTOSCALING_BRANCH=main
LAKEBASE_AGENT_MEMORY_SCHEMA=agent_openai_memory

# --- Action Plane (agents that act) ---
# Set to true once the actions schema exists (scripts/actions_schema_setup.py).
ENABLE_ACTIONS_API=false
# Lakebase instance for the Action Plane tables (often the same instance as memory).
# Workshop default (provisioned + verified). On a Vocareum lab, use your assigned instance.
LAKEBASE_INSTANCE=akzo-workshop-lakebase
LAKEBASE_SCHEMA=akzo_actions
# Mock external-systems app URL for the connectors' SP-direct fallback.
# AKZO_MOCK_SYSTEMS_URL=https://<your-mock-systems-app>.databricksapps.com
AKZO_HTTP_CONNECTION=akzo_external_systems
# Optional explicit SQL warehouse for the governed http_request path.
# DATABRICKS_WAREHOUSE_ID=

# Copy to .env for local development: cp .env.example .env
# Nothing here is a secret — these are workspace/lab-specific config values.
# On Vocareum, use the workspace URL, catalog, warehouse, and Lakebase instance
# assigned to your lab. Never commit a real .env (it is gitignored).

# ── Databricks workspace & CLI ──────────────────────────────────────────────
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
# Optional: named profile from ~/.databrickscfg (omit to use DEFAULT)
# DATABRICKS_CONFIG_PROFILE=

# ── AppKit server / app ─────────────────────────────────────────────────────
DATABRICKS_APP_PORT=8000

# ── Analytics plugin (live "Try it live" SQL panels) ────────────────────────
# SQL warehouse used to run config/queries/*.sql.
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>
# The queries reference tables as schema.table (e.g. akzo_finance.margin_actuals).
# Set your SQL warehouse's default catalog to the workshop catalog so they resolve.

# ── Lakebase (hackathon state: hack_* tables) ───────────────────────────────
# Classic Database Instance name (used to mint short-lived pg credentials).
LAKEBASE_INSTANCE=<your-lakebase-instance>
# Postgres endpoint host for the instance (required).
PGHOST=<your-lakebase-postgres-host>
# Database + schema (defaults shown).
LAKEBASE_DBNAME=databricks_postgres
LAKEBASE_SCHEMA=akzo
# PGDATABASE overrides LAKEBASE_DBNAME if set (AppKit/platform may inject it).
# PGDATABASE=databricks_postgres

# ── Chat / serving (optional, used by content) ──────────────────────────────
DATABRICKS_CHAT_ENDPOINT=databricks-claude-opus-4-7

# ── Client (Vite) — must be VITE_-prefixed to reach the browser bundle ───────
# These drive the read-only catalogue pages (Resources, guides, setup steps).
VITE_DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
VITE_WORKSHOP_CATALOG=<your-uc-catalog>
VITE_LAKEBASE_INSTANCE=<your-lakebase-instance>
VITE_LAKEBASE_DBNAME=databricks_postgres
VITE_LAKEBASE_SCHEMA=akzo
VITE_REPO_BASE=https://github.com/your-org/akzonobel-agentbricks-workshop/blob/main
